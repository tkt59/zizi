-- Liste des joueurs (Troll)
local function RefreshTroll()
    TabPages["Troll"]:ClearAllChildren()
    Instance.new("UIListLayout", TabPages["Troll"]).HorizontalAlignment = Enum.HorizontalAlignment.Center
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local row = Instance.new("Frame")
            row.Size = UDim2.new(0.9, 0, 0, 40)
            row.BackgroundColor3 = C.Surface
            row.Parent = TabPages["Troll"]
            Instance.new("UICorner", row)
            
            local name = Instance.new("TextLabel")
            name.Text = "  " .. plr.Name
            name.Size = UDim2.new(0.5, 0, 1, 0)
            name.BackgroundTransparency = 1
            name.TextColor3 = C.White
            name.TextXAlignment = Enum.TextXAlignment.Left
            name.Parent = row
            
            local tp = Instance.new("TextButton")
            tp.Text = "TP"
            tp.Size = UDim2.new(0, 40, 0, 25)
            tp.Position = UDim2.new(1, -50, 0.5, -12)
            tp.BackgroundColor3 = C.Blue
            tp.Parent = row
            Instance.new("UICorner", tp)
            tp.MouseButton1Click:Connect(function()
                LocalPlayer.Character.HumanoidRootPart.CFrame = plr.Character.HumanoidRootPart.CFrame
            end)
        end
    end
end
